# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_S=60
OPENAI_MAX_RETRIES=3

# ── Rate limiting (shared lab machines) ───────────────────────────────────────
RPM_LIMIT=10

# ── PostgreSQL + pgvector ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://rca:rca@localhost:5432/rca_db

# ── AWS S3 (knowledge-base document store) ────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=its-rca-knowledge-base

# ── Log parser ────────────────────────────────────────────────────────────────
CHUNK_SIZE=8192
CONTEXT_LINES=50

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
